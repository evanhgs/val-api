# === Secret JWT ===
SECRET_KEY=SUP3M3G4p4ss0RWd

# === PostgreSQL (Infrastructure locale) ===
POSTGRES_DB=val_local
POSTGRES_USER=val_local
POSTGRES_PASSWORD=val_local

# === Database URLs ===
# Pour le dev local (schema val_dev dans la meme DB Postgres, port 5432)
DATABASE_URL=postgresql://val_local:val_local@localhost:5432/val_local?options=-csearch_path%3Dval_dev
# Pour les tests (schema val_test dans le meme conteneur Postgres)
DATABASE_URL_TEST=postgresql://val_local:val_local@localhost:5432/val_local?options=-csearch_path%3Dval_test

# === Mosquitto MQTT ===
# Pour le dev local (app tournant hors docker, MQTT tournant dans docker sur le port 1883)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=mqttuser
MQTT_PASSWORD=mqttpassword

# Note: Pour un déploiement complet via docker compose (production), 
# utilisez MQTT_HOST=mqtt-prod et DATABASE_URL=postgresql://val_local:val_local@val-db:5432/val_local
